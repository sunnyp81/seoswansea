---
import Base from '../layouts/Base.astro';

const metaDescription = "Contact SEO Swansea to discuss your search marketing needs. Free SEO audit available for businesses in Swansea, Mumbles, Gower, and across South Wales.";

const faqItems = [
  {
    q: "How quickly will I hear back after contacting SEO Swansea?",
    a: "We respond to all enquiries within one working day. Most messages receive a reply within a few hours during business hours. If your project is urgent, mention it in your message and we will prioritise accordingly."
  },
  {
    q: "What should I include in my initial message?",
    a: "Share your website URL, the location your business serves, and a brief description of what you want to achieve with SEO. This allows us to prepare a more useful initial response. If you are unsure what you need, simply tell us about your business and we will guide you from there."
  },
  {
    q: "Is the initial consultation free?",
    a: "Yes. Every engagement begins with a free SEO audit and consultation. We analyse your website, Google Business Profile, competitors, and local search landscape, then walk you through the findings and recommendations. There is no obligation to proceed after receiving the audit."
  },
  {
    q: "Do you work with businesses outside Swansea?",
    a: "We primarily serve Swansea and South Wales, but we work with businesses anywhere in the UK that need local SEO, technical SEO, or AI search optimisation. The consultancy operates remote-first, so location is not a barrier to working together. Visit our areas page at /areas/ for the full list of locations we cover."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://seoswansea.uk/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Contact",
        "item": "https://seoswansea.uk/contact/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contact SEO Swansea | Get in Touch",
    "url": "https://seoswansea.uk/contact/",
    "description": metaDescription
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  }
];
---

<Base title="Contact SEO Swansea | Get in Touch" description={metaDescription} schema={schema}>

  <article class="space-y-12">

    <header>
      <h1 class="text-3xl font-bold text-brand mb-4">Contact SEO Swansea</h1>
    </header>

    <section class="space-y-4">
      <p class="text-gray-700 leading-relaxed mb-4">
        Contact SEO Swansea to discuss how local search marketing can grow your business. Whether you need a full SEO strategy, a one-off technical audit, or advice on getting started with AI search optimisation, we are here to help. Every conversation starts with understanding your business, your customers, and your goals.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        Fill in the form below or email directly. We respond to all enquiries within one working day and offer a <a href="/free-seo-audit-swansea/" class="text-brand hover:underline">free SEO audit</a> to every new enquiry so you can see exactly where your website stands before committing to anything.
      </p>
    </section>

    <div class="bg-amber-50 border-l-4 border-amber-400 p-4 rounded-r-lg my-6">
      <p class="font-semibold text-amber-900 mb-1">Quick Answer</p>
      <p class="text-amber-800">
        Email <a href="mailto:2012.infinite@gmail.com" class="text-brand hover:underline font-medium">2012.infinite@gmail.com</a> or use the contact form below. We reply within one working day and offer a free SEO audit with every enquiry.
      </p>
    </div>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-gray-900 mt-12 mb-4">Get in Touch</h2>

      <div class="border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-xl font-semibold text-gray-800 mt-0 mb-3">Email</h3>
        <p class="text-gray-700 leading-relaxed mb-4">
          <a href="mailto:2012.infinite@gmail.com" class="text-brand hover:underline">2012.infinite@gmail.com</a>
        </p>
        <h3 class="text-xl font-semibold text-gray-800 mt-8 mb-3">Website</h3>
        <p class="text-gray-700 leading-relaxed mb-4">
          <a href="https://seoswansea.uk" class="text-brand hover:underline">seoswansea.uk</a>
        </p>
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-gray-900 mt-12 mb-4">Send a Message</h2>
      <form action="#" method="POST" class="space-y-5">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
          <input type="text" id="name" name="name" required autocomplete="name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
          <input type="email" id="email" name="email" required autocomplete="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none" />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <input type="tel" id="phone" name="phone" autocomplete="tel" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none" />
        </div>
        <div>
          <label for="website" class="block text-sm font-medium text-gray-700 mb-1">Website URL</label>
          <input type="url" id="website" name="website" placeholder="https://" autocomplete="url" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
          <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-brand focus:border-brand outline-none"></textarea>
        </div>
        <div>
          <button type="submit" class="bg-brand text-white px-8 py-3 rounded-lg hover:bg-brand-dark transition-colors cursor-pointer text-lg font-medium">
            Send Message
          </button>
        </div>
      </form>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-gray-900 mt-12 mb-4">Coverage Area</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        SEO Swansea serves businesses across the city and wider South Wales region. Our primary coverage includes Swansea city centre, Mumbles, Sketty, Morriston, Uplands, and Gorseinon. We also work with businesses in Neath, Port Talbot, Llanelli, and Carmarthen. If your business targets customers in any of these areas, we can help regardless of where you are physically based.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        The consultancy operates remote-first, so we serve clients across the UK. However, our deepest local knowledge covers the Swansea Bay area and the Gower Peninsula, where we understand the seasonal search patterns, local directories, and competitive dynamics that shape SEO strategy for businesses in this region.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        Visit our <a href="/services/" class="text-brand hover:underline">services page</a> to see what we offer, or check <a href="/seo-pricing-swansea/" class="text-brand hover:underline">pricing</a> for package details.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-gray-900 mt-12 mb-4">Find Us</h2>
      <div class="rounded-lg overflow-hidden border border-gray-200">
        <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=-3.99%2C51.59%2C-3.89%2C51.65&layer=mapnik" width="100%" height="300" style="border:0" loading="lazy" title="Map of Swansea"></iframe>
      </div>
      <p class="text-sm text-gray-500 mt-2">Serving Swansea city centre, Mumbles, Sketty, Morriston, Uplands, Gorseinon, and wider South Wales.</p>
    </section>

    <section class="space-y-4 mt-12">
      <h2 class="text-2xl font-semibold text-gray-900 mt-12 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3 mt-6">
        {faqItems.map(item => (
          <details class="border border-gray-200 rounded-lg group">
            <summary class="cursor-pointer font-medium text-gray-900 py-2 flex items-center justify-between p-4 hover:bg-gray-50 transition-colors rounded-lg">
              <span>{item.q}</span>
              <svg class="w-5 h-5 text-gray-500 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-4 pb-4 text-gray-700 leading-relaxed">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="bg-gray-50 rounded-xl p-8 text-center space-y-4 mt-12">
      <h2 class="text-2xl font-semibold text-gray-900">Ready to Start?</h2>
      <p class="text-gray-700 max-w-xl mx-auto">
        Every engagement begins with a free SEO audit. We analyse your website, competitors, and local search landscape so you know exactly where the opportunities are before committing to anything.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-6">
        <a href="/free-seo-audit-swansea/" class="bg-brand text-white px-6 py-3 rounded-lg hover:bg-brand-dark inline-block font-medium transition-colors">
          Request Free Audit
        </a>
        <a href="/about/" class="border border-brand text-brand px-6 py-3 rounded-lg hover:bg-brand hover:text-white transition-colors font-medium inline-block">
          Learn About Us
        </a>
      </div>
    </section>

  </article>

</Base>
