---
import Base from '../layouts/Base.astro';

const metaDescription = "SEO Swansea is a hands-on search marketing team helping local businesses grow through technical SEO, content strategy, and AI search optimisation across Swansea and South Wales.";

const faqItems = [
  {
    q: "Who are SEO Swansea and what do you do?",
    a: "We're a small SEO team based right here in Swansea. We help local businesses get found online through technical audits, content strategy, and AI search optimisation. Think of us as your in-house SEO department, without the overhead of hiring full-time staff."
  },
  {
    q: "Can we meet up in person around Swansea?",
    a: "Of course. We're remote-first across the UK, but we're always happy to sit down over a coffee somewhere in Swansea. Lots of our clients prefer a face-to-face kickoff followed by remote collaboration for the ongoing work. Video calls, screen shares, and monthly reports keep everything transparent either way."
  },
  {
    q: "What kinds of businesses do you work with?",
    a: "We work across a broad range of sectors including tourism and hospitality, healthcare, education, professional services, trades, and tech. Every industry has its own quirks when it comes to search. Our experience across multiple niches means we spot opportunities that a single-sector specialist might miss."
  },
  {
    q: "Why choose SEO Swansea over a big agency in Cardiff or London?",
    a: "Big agencies charge premium retainers and often hand your account to a junior. With us, you deal directly with the people doing the work. We know the difference between search behaviour in Mumbles and Morriston, which local directories actually matter, and how Swansea's seasonal tourism economy shapes search demand. That local knowledge, combined with senior-level skills at fair rates, is hard to find at a large agency."
  },
  {
    q: "Where can I see examples of your results?",
    a: "Head over to our case studies page at /case-studies/ for real examples of SEO campaigns we've delivered. Each one covers the challenge, the strategy, and the measurable results we achieved through organic search."
  },
  {
    q: "I'm not even sure SEO is right for my business. Can we still talk?",
    a: "Absolutely. Drop us a message and we'll have an honest conversation about whether SEO makes sense for you right now. We offer a free audit with every enquiry, so you can see exactly where you stand before deciding anything. No pressure, no hard sell."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://seoswansea.uk/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "About",
        "item": "https://seoswansea.uk/about/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "About SEO Swansea | Our Approach",
    "url": "https://seoswansea.uk/about/",
    "description": metaDescription
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SEO Swansea",
    "url": "https://seoswansea.uk",
    "email": "hello@seoswansea.uk",
    "sameAs": []
  }
];
---

<Base title="About SEO Swansea | Our Approach" description={metaDescription} schema={schema}>

  <article class="space-y-12">

    <header>
      <h1 class="text-3xl font-heading font-bold text-brand mb-4">About SEO Swansea</h1>
    </header>

    <section class="space-y-4">
      <p class="text-text/80 leading-relaxed mb-4">
        We're a small, hands-on SEO team rooted in Swansea. We help local businesses show up where it matters most: in the search results their customers are actually using. Whether that's Google, Bing, or the growing wave of AI-powered search tools like ChatGPT and Copilot, we make sure your business gets found.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        We're not a faceless agency churning through client accounts on a conveyor belt. When you work with us, you deal directly with the people doing the work. No account managers relaying your messages. No outsourced contractors making changes without your knowledge. Just a straightforward relationship with a team that genuinely cares about getting your business more customers through search.
      </p>
    </section>

    <div class="bg-rose-50 border-l-4 border-accent p-4 rounded-r-lg my-6">
      <p class="font-semibold text-text mb-1">Quick Answer</p>
      <p class="text-text/80">
        SEO Swansea is a small, local SEO team offering technical SEO, local SEO, content strategy, and AI search optimisation for businesses across Swansea and South Wales. <a href="/free-seo-audit-swansea/" class="text-accent hover:underline font-medium">Grab a free audit</a> or <a href="/contact/" class="text-accent hover:underline font-medium">drop us a message</a> to get started.
      </p>
    </div>

    <section class="space-y-4">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Who We Are</h2>
      <p class="text-text/80 leading-relaxed mb-4">
        We're a team of SEO practitioners. That means we don't just talk strategy and hand you a PDF. We build websites, audit technical infrastructure, write content strategies, implement structured data, and monitor search performance across every site we manage. This hands-on approach means we encounter and solve the same technical problems your business faces, week after week, across dozens of different industries and platforms.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        Between us, we manage a portfolio of over 40 websites across competitive niches. That gives us something most consultants can't offer: real-time pattern recognition. When Google rolls out a core update, we see the impact across dozens of sites simultaneously. We know what works and what doesn't because we've got the data to prove it, not because we read about it on a blog.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        We've also invested heavily in understanding the new frontier of AI search. As tools like Google AI Overviews, ChatGPT, Microsoft Copilot, and Perplexity reshape how people discover businesses, we help our clients get their websites cited and surfaced by these platforms. It's an increasingly important edge for Swansea businesses competing for visibility in a search landscape that changes fast. Learn more about our <a href="/ai-search-optimisation-swansea/" class="text-accent hover:underline font-medium">AI search optimisation service</a>.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Our Approach</h2>
      <p class="text-text/80 leading-relaxed mb-4">
        Every project we take on follows the same core principles: let the data lead, be completely transparent, avoid anything shady, and build rankings that last.
      </p>

      <h3 class="text-xl font-heading font-semibold text-brand-light mt-8 mb-3">Data First, Always</h3>
      <p class="text-text/80 leading-relaxed mb-4">
        We never recommend anything based on a hunch. Every strategy starts with data from Google Search Console, keyword research tools, and competitor analysis. We pinpoint which searches your potential customers are actually making, how your website currently stacks up, and where the biggest opportunities lie. Your budget goes toward the actions most likely to bring in revenue, not toward ticking boxes on a generic SEO checklist.
      </p>

      <h3 class="text-xl font-heading font-semibold text-brand-light mt-8 mb-3">Plain-Language Reporting</h3>
      <p class="text-text/80 leading-relaxed mb-4">
        You get full access to your Google Search Console and analytics data. Our monthly reports show keyword movements, traffic trends, completed work, and the plan for next month. No black-box summaries. No jargon-filled charts designed to impress rather than inform. We show you the raw numbers and explain what they mean in plain English.
      </p>

      <h3 class="text-xl font-heading font-semibold text-brand-light mt-8 mb-3">No Dodgy Tactics</h3>
      <p class="text-text/80 leading-relaxed mb-4">
        We don't use link schemes, private blog networks, keyword stuffing, cloaking, or any technique that breaks Google's rules. Those shortcuts sometimes deliver a short-term bump, but they inevitably lead to penalties that can wipe out months or years of progress. Everything we do is sustainable, ethical, and designed to build lasting authority. Your reputation is too important to gamble with.
      </p>

      <h3 class="text-xl font-heading font-semibold text-brand-light mt-8 mb-3">Traditional SEO Meets AI Search</h3>
      <p class="text-text/80 leading-relaxed mb-4">
        Search isn't just about Google's ten blue links any more. AI-powered tools are changing how people find and evaluate businesses. We integrate AI search optimisation alongside traditional SEO, making sure your website is structured and written so that both search engines and AI systems can extract, understand, and cite your content. It's a forward-looking capability that most agencies haven't caught up with yet.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Why Swansea</h2>
      <p class="text-text/80 leading-relaxed mb-4">
        Swansea is a city with layers that outsiders miss. The tourism economy around the Gower Peninsula and Swansea Bay creates seasonal search demand that businesses can capture with the right content at the right time. The healthcare hub at Morriston Hospital anchors a cluster of medical and wellness services with high-value search intent. The tech startups at SA1 Waterfront need SEO from day one. And the education sector around Swansea University generates year-round search demand from students, parents, and academics.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        This matters because search behaviour in Swansea is genuinely different from search behaviour in Cardiff, Bristol, or London. A tourist near Mumbles searching for a restaurant has different intent from a Morriston resident looking for a plumber. A Swansea University student hunting for a tutor uses different search patterns from a parent in Sketty doing the same thing. Local SEO that ignores these distinctions produces generic results. We account for them because we live and work in this community.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        The Swansea market also sits in a competitive sweet spot. With over 240,000 residents and millions of annual visitors drawn to landmarks like the National Waterfront Museum, Swansea Bay, and the Gower, there's real search volume across most commercial categories. Yet SEO competition is far less intense than in major English cities. Many Swansea businesses still rely entirely on word of mouth or social media. That means a well-executed SEO campaign delivers faster, more visible results than the same effort would in a saturated market.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">What We Do Best</h2>
      <p class="text-text/80 leading-relaxed mb-4">
        SEO is a broad discipline. Many consultants specialise in one area and outsource the rest. Our team covers the full stack, which means faster turnaround, fewer communication gaps, and a joined-up strategy where every piece reinforces the others.
      </p>
      <div class="grid md:grid-cols-2 gap-4 mt-4">
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Technical SEO</h3>
          <p class="text-sm text-text/80">Site speed, Core Web Vitals, crawlability, indexation, server configuration, mobile usability, and structured data. The foundation every ranking depends on.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Local SEO</h3>
          <p class="text-sm text-text/80">Google Business Profile optimisation, citation building, local schema markup, review generation, and geo-targeted content. Built specifically for businesses serving Swansea and South Wales.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Content Strategy</h3>
          <p class="text-sm text-text/80">Semantic keyword research, topical authority mapping, content gap analysis, and editorial planning. Content designed to match search intent and build authority across your entire topic space.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">AI Search Optimisation (AEO/GEO)</h3>
          <p class="text-sm text-text/80">Answer Engine Optimisation and Generative Engine Optimisation. Structuring content and data so AI tools like ChatGPT, Copilot, and Google AI Overviews cite your business in their responses.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Google Business Profile</h3>
          <p class="text-sm text-text/80">Complete GBP management including category selection, service descriptions, photo strategy, Q&A monitoring, review responses, and performance tracking through GBP Insights.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Structured Data and Schema</h3>
          <p class="text-sm text-text/80">JSON-LD implementation for LocalBusiness, FAQPage, Article, BreadcrumbList, Product, and dozens of other schema types. Rich snippets that improve click-through rates.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Site Speed Optimisation</h3>
          <p class="text-sm text-text/80">Image compression, lazy loading, critical CSS, JavaScript deferral, caching strategies, and CDN configuration. Faster pages rank higher and convert better.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-4">
          <h3 class="font-semibold text-text mb-2">Analytics and Reporting</h3>
          <p class="text-sm text-text/80">Google Search Console, GA4, and custom dashboards. Data collection, analysis, and plain-language reporting that shows exactly what your SEO investment is delivering.</p>
        </div>
      </div>
      <p class="text-text/80 leading-relaxed mb-4 mt-4">
        See the full range of <a href="/services/" class="text-accent hover:underline font-medium">SEO services</a> we offer, or check our <a href="/seo-pricing-swansea/" class="text-accent hover:underline font-medium">pricing page</a> for package details.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Why Not a Big Agency</h2>
      <p class="text-text/80 leading-relaxed mb-4">
        Large SEO agencies in Cardiff and London charge premium retainers, often several thousand pounds a month. For that fee, your account is typically managed by a junior team member following templated processes. The senior strategist you met during the sales pitch rarely touches your account after the contract is signed. Communication passes through an account manager, adding delays and losing technical nuance along the way.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        With SEO Swansea, there's no chain of communication. Our team handles strategy, execution, and reporting directly. When you get in touch, you reach the people who wrote your last technical audit and know your Search Console data inside out. That direct relationship cuts out the overhead, miscommunication, and quality wobbles that plague larger operations.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        The cost difference is real, too. Our rates are lower than agency retainers because we don't have an office lease, a sales team on commission, or layers of middle management to fund. You pay for SEO work, not agency infrastructure. And the savings don't come at the expense of capability. The same technical skills, the same strategic depth, the same reporting standards, just without the bloat.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        Then there's the local knowledge. A London agency servicing a Swansea client won't understand why search patterns differ between SA1 and SA6, or why tourism queries spike when the Gower Peninsula appears in a national travel supplement. Those details matter for local SEO, and they come from genuine familiarity with the area, not from desk research.
      </p>
      <p class="text-text/80 leading-relaxed mb-4">
        Have a look at our <a href="/case-studies/" class="text-accent hover:underline font-medium">case studies</a> to see the kind of results this approach delivers.
      </p>
    </section>

    <section class="bg-gray-50 rounded-xl p-8 text-center space-y-4 mt-12">
      <h2 class="text-2xl font-heading font-semibold text-text">Ready to Grow Your Swansea Business Through Search?</h2>
      <p class="text-text/80 max-w-xl mx-auto">
        Let's start with a free SEO audit. We'll look at your website, your competitors, and the local search landscape, then show you exactly where the opportunities are. No obligation, no hard sell.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-6">
        <a href="/free-seo-audit-swansea/" class="bg-accent text-brand px-6 py-3 rounded-lg hover:bg-accent/80 font-semibold inline-block">
          Request Free Audit
        </a>
        <a href="/contact/" class="border border-brand text-brand px-6 py-3 rounded-lg hover:bg-brand hover:text-white transition-colors font-semibold inline-block">
          Drop Us a Message
        </a>
      </div>
    </section>

    <section class="space-y-4 mt-12">
      <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3 mt-6">
        {faqItems.map(item => (
          <details class="border border-gray-200 rounded-lg group">
            <summary class="cursor-pointer font-medium text-text py-2 flex items-center justify-between p-4 hover:bg-gray-50 transition-colors rounded-lg">
              <span>{item.q}</span>
              <svg class="w-5 h-5 text-gray-500 flex-shrink-0 ml-4 group-open:rotate-180 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-4 pb-4 text-text/80 leading-relaxed">
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

  </article>

</Base>
