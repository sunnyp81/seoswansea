            <td class="border border-gray-200 px-4 py-3 text-gray-700">£1,200 - £1,500</td>
            <td class="border border-gray-200 px-4 py-3 text-gray-700">£1,500 - £2,000</td>
          </tr>
          <tr>
            <td class="border border-gray-200 px-4 py-3 text-gray-700">Enterprise / Premium</td>
            <td class="border border-gray-200 px-4 py-3 text-brand font-semibold">£1,997</td>
            <td class="border border-gray-200 px-4 py-3 text-gray-700">£2,500 - £3,500</td>
            <td class="border border-gray-200 px-4 py-3 text-gray-700">£3,000 - £5,000</td>
          </tr>
        </tbody>
      </table>
