      <path d="M230 80 L258 80" stroke="#334155" stroke-width="2" fill="none" marker-end="url(#arrowhead)" />
      <!-- Box 3: AI Crawler -->
      <rect x="258" y="40" width="100" height="80" rx="6" fill="#334155" />
      <text x="308" y="66" text-anchor="middle" fill="white" font-size="10" font-weight="600" font-family="Inter, sans-serif">AI Crawler</text>
