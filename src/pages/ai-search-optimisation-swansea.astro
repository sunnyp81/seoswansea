      <!-- Arrow 2 -->
      <path d="M230 80 L258 80" stroke="#1e40af" stroke-width="2" fill="none" marker-end="url(#arrowhead)" />
      <!-- Box 3: AI Crawler -->
      <rect x="258" y="40" width="100" height="80" rx="6" fill="#1e40af" />
      <text x="308" y="66" text-anchor="middle" fill="white" font-size="10" font-weight="600" font-family="Inter, sans-serif">AI Crawler</text>
      <text x="308" y="82" text-anchor="middle" fill="white" font-size="8" font-family="Inter, sans-serif" opacity="0.8">GPTBot</text>
      <text x="308" y="94" text-anchor="middle" fill="white" font-size="8" font-family="Inter, sans-serif" opacity="0.8">ClaudeBot</text>
      <text x="308" y="106" text-anchor="middle" fill="white" font-size="8" font-family="Inter, sans-serif" opacity="0.8">PerplexityBot</text>
      <!-- Arrow 3 -->
      <path d="M358 80 L386 80" stroke="#1e40af" stroke-width="2" fill="none" marker-end="url(#arrowhead)" />
      <!-- Box 4: LLM Processing -->
