import Base from '../layouts/Base.astro';

const title = "AI Search Optimisation Swansea | AEO & GEO";
const description = "AI search optimisation services in Swansea. We help local businesses appear in ChatGPT, Google AI Overviews, Copilot and Perplexity results with AEO and GEO.";

const faqs = [
  {
    q: "What is AI search optimisation?",
    a: "AI search optimisation is the practice of structuring your website content so that large language models and AI-powered search engines can find, understand, and cite your business in their generated answers. It combines Answer Engine Optimisation (AEO), Generative Engine Optimisation (GEO), and LLM SEO techniques to ensure your brand appears when customers ask AI assistants questions relevant to your services."
  },
  {
    q: "How is AEO different from traditional SEO?",
    a: "Traditional SEO focuses on ranking web pages in a list of blue links by optimising for keywords, building backlinks, and improving technical signals. AEO focuses on getting your business cited as a source in AI-generated answers by optimising for entities, structured data, declarative content, and citation patterns. Both disciplines overlap, but AEO requires a fundamentally different content strategy centred on direct answers rather than click-through rates."
  },
  {
    q: "What is GEO (Generative Engine Optimisation)?",
    a: "GEO is a subset of AI search optimisation that specifically targets generative search results such as Google AI Overviews, ChatGPT search, and Perplexity answers. GEO involves crafting content that generative models are likely to synthesise into their responses, including authoritative statistics, unique data, expert quotes, and entity-rich prose that co-occurs with trusted sources in the training data."
  },
  {
    q: "Do Swansea businesses really need AI search optimisation?",
    a: "Yes. AI search tools already handle a significant share of local queries in Wales. When someone asks Copilot for the best plumber in Morriston or ChatGPT for restaurant recommendations in Mumbles, the AI pulls from indexed web content. If your site is not optimised for AI extraction, your competitors who are optimised will be cited instead. Early movers in AI search gain a compounding advantage that is difficult to reverse."
  },
  {
    q: "What is llms.txt and do I need one?",
    a: "llms.txt is a proposed standard file (similar to robots.txt) that tells AI crawlers what your site is about, what content is most important, and how to attribute your brand. It sits at yourdomain.com/llms.txt and provides a structured summary that helps language models understand your site without crawling every page. We recommend every Swansea business implements one as part of their AI search strategy."
  },
  {
    q: "Will AI search optimisation hurt my Google rankings?",
    a: "No. AI search optimisation complements traditional SEO rather than replacing it. The techniques involved, such as improving structured data, writing clearer content, and strengthening entity signals, also benefit your Google rankings. In fact, Google AI Overviews draw from the same index as organic results, so optimising for AI extraction typically improves both channels simultaneously."
  },
  {
    q: "How long does it take to see results from AI search optimisation?",
    a: "Initial improvements in structured data and content clarity can be indexed within days. However, appearing consistently in AI-generated answers typically takes four to twelve weeks as crawlers re-index your content and models update their knowledge bases. Citation monitoring shows measurable changes within the first month for most Swansea businesses we work with."
  },
  {
    q: "How much does AI search optimisation cost in Swansea?",
    a: "Our AI search optimisation packages start from a one-off audit and implementation at a fixed fee, with optional monthly monitoring retainers. Pricing depends on the size of your site, the number of service areas, and the competitive landscape. Visit our pricing page or request a free AI search audit to get a tailored quote for your Swansea business."
  }
];

