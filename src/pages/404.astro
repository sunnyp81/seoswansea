---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found — Bay SEO Studio" description="The page you're looking for doesn't exist. Browse our SEO services for Swansea businesses.">
  <div class="text-center py-16">
    <h1 class="text-4xl font-bold text-brand mb-4">404 — Page Not Found</h1>
    <p class="text-lg text-text-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <div class="space-x-4">
      <a href="/" class="inline-block bg-brand text-white px-6 py-3 rounded-lg hover:bg-brand-dark transition-colors">Go Home</a>
      <a href="/contact/" class="inline-block border border-brand text-brand px-6 py-3 rounded-lg hover:bg-brand hover:text-white transition-colors">Contact Us</a>
    </div>
  </div>
</Base>
