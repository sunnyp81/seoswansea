---
import Base from '../layouts/Base.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seoswansea.uk/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://seoswansea.uk/services/" },
      { "@type": "ListItem", "position": 3, "name": "Free SEO Audit", "item": "https://seoswansea.uk/free-seo-audit-swansea/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Free SEO Audit Swansea | Get Yours Now | SEO Swansea",
    "description": "Get a free SEO audit for your Swansea business. We check site speed, mobile usability, on-page SEO, and local visibility then send you a report with quick wins.",
    "url": "https://seoswansea.uk/free-seo-audit-swansea/",
    "publisher": { "@type": "Organization", "name": "SEO Swansea", "url": "https://seoswansea.uk", "sameAs": [] }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is this genuinely free, no strings attached?",
        "acceptedAnswer": { "@type": "Answer", "text": "Completely. No charge, no obligation, no card details needed. We review your website and send you a report highlighting the key issues and opportunities. What you do with it is entirely up to you. There is no sales call unless you ask for one." }
      },
      {
        "@type": "Question",
        "name": "When will the report land in my inbox?",
        "acceptedAnswer": { "@type": "Answer", "text": "Within 2 working days of submitting the form. Most reports land the same day or the following morning, depending on when you send your request through." }
      },
      {
        "@type": "Question",
        "name": "What information do you need from me?",
        "acceptedAnswer": { "@type": "Answer", "text": "Just your name, email address, website URL, and your business location in Swansea. We do not need access to your hosting, CMS, or any accounts. The free audit is based entirely on what we can see from the public-facing version of your site." }
      },
      {
        "@type": "Question",
        "name": "How does this compare to the full paid audit?",
        "acceptedAnswer": { "@type": "Answer", "text": "The free audit covers the headline issues: site speed, mobile usability, on-page SEO basics, and local visibility signals. The full paid audit adds hands-on analysis by our team, 16 months of Search Console data, backlink profile review, competitor benchmarking, and a prioritised action plan with a walkthrough call. Visit our SEO audit page for full details on the paid option." }
      },
      {
        "@type": "Question",
        "name": "Can I use the free audit to handle SEO on my own?",
        "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. The report includes specific, actionable recommendations you or your developer can run with straight away. Lots of Swansea business owners use the free audit to handle the basics in-house and then come back to us for the trickier technical and strategic work." }
      }
    ]
  }
];
---

<Base title="Free SEO Audit Swansea | Get Yours Now | SEO Swansea" description="Get a free SEO audit for your Swansea business. We check site speed, mobile usability, on-page SEO, and local visibility then send you a report with actionable quick wins." schema={schema}>

  <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
    <a href="/" class="text-accent hover:underline font-medium">Home</a>
    <span class="mx-1">/</span>
    <a href="/services/" class="text-accent hover:underline font-medium">Services</a>
    <span class="mx-1">/</span>
    <span class="text-gray-700">Free SEO Audit</span>
  </nav>

  <h1 class="text-3xl font-heading font-bold text-brand mb-4">Free SEO Audit for Swansea Businesses</h1>

  <p class="text-text/80 leading-relaxed mb-4">Our free SEO audit is a no-strings health check for your website. We look at your site speed, mobile usability, on-page SEO, and local visibility signals, then send you a clear report showing what's working, what isn't, and what to fix first. It's built for Swansea business owners who want honest, data-backed answers about their search presence without having to commit to anything.</p>

  <div class="bg-rose-50 border-l-4 border-accent p-4 rounded-r-lg my-6">
    <p class="font-medium text-text mb-1">Quick Answer</p>
    <p class="text-text/80">Pop your website URL into the form below and we'll send you a free SEO report within 2 working days. No obligation, no sales call. We check speed, mobile friendliness, on-page SEO, and local signals, then tell you what to tackle first.</p>
  </div>

  <p class="text-text/80 leading-relaxed mb-4">Whether you run a cafe in Mumbles, a consultancy at SA1 Waterfront, or a trades business serving the Gower Peninsula, this free audit gives you a practical starting point. You'll know whether your website is helping or hindering your ability to win customers through Google — and you'll have specific steps you can take straight away to improve things.</p>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">What You'll Get in the Free Audit</h2>

  <p class="text-text/80 leading-relaxed mb-4">The free audit covers the four areas that make the biggest difference to how your Swansea business shows up in search results. Each section includes a score or status indicator along with plain-English recommendations.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>Site speed analysis.</strong> We measure your page load time and Core Web Vitals on both mobile and desktop. Slow pages lose visitors and rank lower. The report tells you exactly what's dragging things down — whether that's bloated images, render-blocking scripts, or a sluggish server — and how to sort it out.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>Mobile usability check.</strong> Over 60 percent of local searches in Swansea happen on a phone. We test your site across different screen sizes and flag problems like text that's too small, buttons squashed too close together, annoying horizontal scrolling, and content that breaks on mobile. Since Google uses mobile-first indexing, mobile usability has a direct effect on your rankings across all devices.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>On-page SEO review.</strong> We check your title tags, meta descriptions, heading structure, and content quality on your key pages. Missing or duplicate titles, weak meta descriptions, and sloppy heading hierarchy are among the most common on-page issues we spot on Swansea business websites. They're often the fastest fixes with the most immediate ranking payoff.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>Local SEO visibility signals.</strong> We look at your Google Business Profile presence, check for basic local schema markup, and assess whether your website is set up for location-based searches. For businesses serving Swansea, the Gower, and the surrounding area, local SEO signals decide whether you show up in Google's local pack and map results when potential customers search nearby.</p>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">How It Works</h2>

  <p class="text-text/80 leading-relaxed mb-4">Getting your free audit takes three simple steps. No calls, no commitments, no catches.</p>

  <div class="grid gap-6 md:grid-cols-3 my-6">
    <div class="bg-gray-50 rounded-lg p-5 text-center">
      <p class="text-2xl font-bold text-brand mb-2">1</p>
      <p class="font-semibold text-text mb-1">Fill In the Form</p>
      <p class="text-text/80 text-sm">Enter your name, email, website URL, and business location in Swansea using the form below.</p>
    </div>
    <div class="bg-gray-50 rounded-lg p-5 text-center">
      <p class="text-2xl font-bold text-brand mb-2">2</p>
      <p class="font-semibold text-text mb-1">We Take a Look</p>
      <p class="text-text/80 text-sm">We run automated checks and a manual review covering speed, mobile, on-page SEO, and local visibility.</p>
    </div>
    <div class="bg-gray-50 rounded-lg p-5 text-center">
      <p class="text-2xl font-bold text-brand mb-2">3</p>
      <p class="font-semibold text-text mb-1">Your Report Arrives</p>
      <p class="text-text/80 text-sm">The report lands in your inbox within 2 working days with scores, findings, and prioritised recommendations.</p>
    </div>
  </div>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">What We Check</h2>

  <p class="text-text/80 leading-relaxed mb-4">The free audit examines the following areas of your website. Every check produces a specific finding with a clear recommendation.</p>

  <ul class="text-text/80 leading-relaxed mb-4 space-y-2 list-disc list-inside">
    <li>Page load speed on mobile and desktop with Core Web Vitals scores</li>
    <li>Mobile responsiveness and touch-target sizing</li>
    <li>Title tag length, uniqueness, and keyword relevance</li>
    <li>Meta description presence and quality</li>
    <li>Heading hierarchy and H1 tag usage</li>
    <li>HTTPS status and SSL certificate validity</li>
    <li>Broken links and redirect issues on your key pages</li>
    <li>Image optimisation including alt text, file size, and modern formats</li>
    <li>Google Business Profile presence and basic completeness</li>
    <li>Local schema markup detection</li>
    <li>Robots.txt and XML sitemap accessibility</li>
  </ul>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Who Is This For?</h2>

  <p class="text-text/80 leading-relaxed mb-4">The free SEO audit is for Swansea business owners and marketers who want a clear, honest picture of their website's search performance. It's especially handy if any of these sound like you.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>You've never had an SEO audit.</strong> If your website's been live for more than six months and nobody's checked its SEO performance, the free audit will almost certainly turn up issues you had no idea about. Most Swansea websites we look at have at least three or four quick wins that can be acted on the same week.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>You're thinking about investing in SEO.</strong> Before committing to a retainer, the free audit gives you an independent read on where you stand. It helps you understand the scale of work involved and whether the potential return stacks up for your Swansea business.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>You want to compare agencies.</strong> If you're weighing up a few SEO providers in Swansea or South Wales, our free audit gives you a benchmark. Compare our findings against what other agencies are telling you and make a decision based on substance, not sales pitches.</p>

  <p class="text-text/80 leading-relaxed mb-4"><strong>You're a new business in Swansea.</strong> If you've recently set up in Mumbles, SA1 Waterfront, the Gower, or anywhere across Swansea, the free audit makes sure your website is properly configured for local search from the start. Catching issues early stops them snowballing over time.</p>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4" id="form">Grab Your Free SEO Audit</h2>

  <p class="text-text/80 leading-relaxed mb-4">Fill in the form below and we'll send your free SEO audit report within 2 working days. No obligation, no sales call.</p>

  <form action="#" method="POST" class="bg-gray-50 border border-gray-200 rounded-lg p-6 space-y-4 my-6">
    <div>
      <label for="name" class="block text-sm font-medium text-text mb-1">Your Name</label>
      <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none" placeholder="e.g. Rhys Davies" />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-text mb-1">Email Address</label>
      <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none" placeholder="you@yourbusiness.co.uk" />
    </div>
    <div>
      <label for="website" class="block text-sm font-medium text-text mb-1">Website URL</label>
      <input type="url" id="website" name="website" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none" placeholder="https://www.yourbusiness.co.uk" />
    </div>
    <div>
      <label for="location" class="block text-sm font-medium text-text mb-1">Business Location in Swansea</label>
      <input type="text" id="location" name="location" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent outline-none" placeholder="e.g. SA1 Waterfront, Mumbles, Uplands" />
    </div>
    <button type="submit" class="bg-accent text-brand px-6 py-3 rounded-lg hover:bg-accent/80 font-semibold inline-block w-full sm:w-auto">Grab Your Free Audit</button>
    <p class="text-xs text-gray-500">We only use your email to send the audit report. No spam, no mailing list.</p>
  </form>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Want More Depth? Upgrade to a Full Audit</h2>

  <p class="text-text/80 leading-relaxed mb-4">The free audit covers the essentials, but if you want the full picture, our <a href="/seo-audit-swansea/" class="text-accent hover:underline font-medium">full SEO audit</a> goes significantly deeper. The paid version includes hands-on analysis by our team, 16 months of Google Search Console data, a complete backlink profile review, competitor benchmarking against your top Swansea rivals, and a 30-minute strategy call to talk through findings and next steps.</p>

  <p class="text-text/80 leading-relaxed mb-4">Plenty of Swansea businesses start with the free audit and upgrade once they see the value. There's zero pressure. The free report stands on its own as a useful, actionable piece of work. But if you want the level of detail that drives a serious SEO strategy, the full audit is the natural next step. Pricing starts from £500, with full details on our <a href="/seo-pricing-swansea/" class="text-accent hover:underline font-medium">pricing page</a>.</p>

  <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 my-8 text-center">
    <p class="text-lg font-semibold text-text mb-2">Not sure which audit you need?</p>
    <p class="text-text/80 mb-4">Start with the free one. If the findings call for deeper analysis, we'll let you know.</p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="#form" class="bg-accent text-brand px-6 py-3 rounded-lg hover:bg-accent/80 font-semibold inline-block">Grab Your Free Audit</a>
      <a href="/contact/" class="border border-accent text-accent px-6 py-3 rounded-lg hover:bg-accent hover:text-brand inline-block transition-colors font-semibold">Drop Us a Message</a>
    </div>
  </div>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Frequently Asked Questions</h2>

  <div class="space-y-2 mb-8">
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="cursor-pointer font-medium text-text py-2">Is this genuinely free, no strings attached?</summary>
      <p class="text-text/80 leading-relaxed mt-2">Completely. No charge, no obligation, no card details needed. We review your website and send you a report highlighting the key issues and opportunities. What you do with it is entirely up to you. There's no sales call unless you ask for one.</p>
    </details>

    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="cursor-pointer font-medium text-text py-2">When will the report land in my inbox?</summary>
      <p class="text-text/80 leading-relaxed mt-2">Within 2 working days of submitting the form. Most reports land the same day or the following morning, depending on when you send your request through.</p>
    </details>

    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="cursor-pointer font-medium text-text py-2">What information do you need from me?</summary>
      <p class="text-text/80 leading-relaxed mt-2">Just your name, email address, website URL, and your business location in Swansea. We don't need access to your hosting, CMS, or any accounts. The free audit is based entirely on what we can see from the public-facing version of your site.</p>
    </details>

    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="cursor-pointer font-medium text-text py-2">How does this compare to the full paid audit?</summary>
      <p class="text-text/80 leading-relaxed mt-2">The free audit covers the headline issues: site speed, mobile usability, on-page SEO basics, and local visibility signals. The full paid audit adds hands-on analysis by our team, 16 months of Search Console data, backlink profile review, competitor benchmarking, and a prioritised action plan with a walkthrough call. Visit our <a href="/seo-audit-swansea/" class="text-accent hover:underline font-medium">SEO audit page</a> for full details on the paid option.</p>
    </details>

    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="cursor-pointer font-medium text-text py-2">Can I use the free audit to handle SEO on my own?</summary>
      <p class="text-text/80 leading-relaxed mt-2">Absolutely. The report includes specific, actionable recommendations you or your developer can run with straight away. Lots of Swansea business owners use the free audit to handle the basics in-house and then come back to us for the trickier technical and strategic work.</p>
    </details>
  </div>

  <h2 class="text-2xl font-heading font-semibold text-text mt-12 mb-4">Related Pages</h2>

  <ul class="text-text/80 leading-relaxed mb-4 space-y-2">
    <li><a href="/seo-audit-swansea/" class="text-accent hover:underline font-medium">Full SEO Audit</a> — comprehensive five-pillar analysis with competitor benchmarking and strategy call</li>
    <li><a href="/services/" class="text-accent hover:underline font-medium">All Services</a> — the full range of SEO services we offer to Swansea businesses</li>
    <li><a href="/seo-pricing-swansea/" class="text-accent hover:underline font-medium">SEO Pricing</a> — clear pricing for audits, retainers, and one-off projects</li>
    <li><a href="/contact/" class="text-accent hover:underline font-medium">Contact</a> — drop us a message with a question or to talk about your SEO needs</li>
  </ul>

</Base>
