---
import Base from '../layouts/Base.astro';

const metaDescription = "SEO Swansea helps local businesses get found on Google. Friendly SEO advice, plain-English reporting, and real results for Swansea and South Wales companies.";

const faqItems = [
  {
    q: "How quickly will we see SEO results in Swansea?",
    a: "Most Swansea businesses start noticing ranking improvements within three to six months. Local SEO often kicks in faster because there's less competition in the SA postcode areas than in Cardiff or London. We keep an eye on progress weekly through Google Search Console and send you a straightforward monthly report so you always know where things stand."
  },
  {
    q: "How much does SEO cost for a Swansea business?",
    a: "Our ongoing local SEO packages start from £350 a month. If you just want a one-off technical audit, those start at £250. Every project begins with a free SEO audit so we can figure out exactly what you need. Pop over to /seo-pricing-swansea/ for the full breakdown."
  },
  {
    q: "We get most of our customers through word of mouth — is SEO still worth it?",
    a: "Word of mouth is brilliant, but eight out of ten people now look you up online before they visit. If someone hears about your Swansea shop and then searches your name, a weak online presence can lose you the sale. SEO backs up your reputation by making sure your website shows up when people come looking."
  },
  {
    q: "What exactly is local SEO, and why does it matter in Swansea?",
    a: "Local SEO is all about making sure your website and Google Business Profile show up when people search for services nearby. When someone in Mumbles searches for a plumber, or a tourist near the Gower Peninsula looks for somewhere to eat, local SEO decides which businesses pop up in the map pack and organic results. For Swansea businesses going up against national chains, it's the most cost-effective way to win customers right on your doorstep."
  },
  {
    q: "Can you help with our Google Business Profile?",
    a: "Absolutely. Google Business Profile management comes with all our SEO packages. We'll get your listing looking sharp with the right categories, clear service descriptions, good photos, and a plan for getting more reviews. For businesses near landmarks like the Liberty Stadium or the National Waterfront Museum, we also tap into proximity signals to help you show up in the map pack."
  },
  {
    q: "Should a Swansea business invest in SEO or paid ads?",
    a: "Paid ads get you instant visibility, but the moment you stop paying, they vanish. SEO builds lasting organic rankings that keep bringing in traffic and leads month after month. For most Swansea SMEs, a bit of both works well: paid ads for short-term pushes and SEO for steady long-term growth. We focus on SEO because it gives you the best return over time."
  },
  {
    q: "Are AI search tools like ChatGPT going to affect my business?",
    a: "They already are. Tools like ChatGPT, Google AI Overviews, and Microsoft Copilot pull answers from well-structured websites. Businesses that get ahead of this now will pick up traffic their competitors miss. Our AI search optimisation service gets your Swansea business ready for this shift. Have a look at /ai-search-optimisation-swansea/ for more details."
  },
  {
    q: "Do you work with businesses outside the Swansea area?",
    a: "We mainly work with businesses across Swansea, Neath Port Talbot, Llanelli, and the wider South Wales region. If your customers are in these areas, we can help — no matter where you're actually based. Check out /areas/ for the full list of locations we cover."
  }
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "SEO Swansea",
    "url": "https://seoswansea.uk",
    "email": "hello@seoswansea.uk",
    "sameAs": []
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "SEO Swansea",
    "url": "https://seoswansea.uk",
    "email": "hello@seoswansea.uk",
    "areaServed": [
      { "@type": "City", "name": "Swansea" },
      { "@type": "Place", "name": "Mumbles" },
      { "@type": "Place", "name": "Sketty" },
      { "@type": "Place", "name": "Morriston" },
      { "@type": "Place", "name": "Uplands" },
      { "@type": "Place", "name": "Gorseinon" },
      { "@type": "Place", "name": "Neath" },
      { "@type": "Place", "name": "Port Talbot" },
      { "@type": "Place", "name": "Llanelli" },
      { "@type": "AdministrativeArea", "name": "South Wales" }
    ],
    "serviceType": "Search Engine Optimisation"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://seoswansea.uk/"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "SEO Swansea — Local SEO for Swansea & South Wales Businesses",
    "url": "https://seoswansea.uk/",
    "description": metaDescription
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a
      }
    }))
  }
];
---

<Base title="SEO Swansea | Local SEO in Swansea" description={metaDescription} schema={schema}>

  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h1 class="text-4xl md:text-5xl font-heading font-extrabold text-brand leading-[1.1] tracking-tight">
          Grow Your Swansea Business Through Search
        </h1>
        <p class="text-lg text-text-muted leading-relaxed max-w-lg">
          Local SEO that puts your business in front of customers actively searching for what you offer. No fluff, no jargon — just measurable rankings growth.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-2">
          <a href="/free-seo-audit-swansea/" class="relative overflow-hidden bg-accent text-white px-6 py-3.5 rounded-xl font-semibold shadow-lg shadow-accent/25 hover:shadow-xl hover:shadow-accent/30 transition-shadow">
            <span class="relative z-10">Get Your Free SEO Audit</span>
            <div class="absolute inset-0 -translate-x-full animate-shimmer" style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);"></div>
          </a>
          <a href="/seo-pricing-swansea/" class="border-2 border-brand/20 text-brand px-6 py-3.5 rounded-xl font-semibold hover:border-brand/40 hover:bg-brand/5 transition-colors">
            View Pricing
          </a>
        </div>
      </div>
      <!-- Growth Chart SVG -->
      <div class="fade-up relative" style="transition-delay: 200ms">
        <div class="glass-card rounded-2xl p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm font-medium text-text-muted">Organic Traffic Growth</span>
            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium">+147%</span>
          </div>
          <svg viewBox="0 0 300 120" class="w-full" aria-label="Growth chart showing upward trend">
            <defs>
              <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#FB7185" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#FB7185" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="M0,100 Q30,95 60,88 T120,72 T180,50 T240,30 T300,10" fill="none" stroke="#FB7185" stroke-width="2.5" class="growth-line"/>
            <path d="M0,100 Q30,95 60,88 T120,72 T180,50 T240,30 T300,10 L300,120 L0,120 Z" fill="url(#chartGrad)" opacity="0.6"/>
            <!-- Data points -->
            <circle cx="60" cy="88" r="3" fill="#FB7185"/>
            <circle cx="120" cy="72" r="3" fill="#FB7185"/>
            <circle cx="180" cy="50" r="3" fill="#FB7185"/>
            <circle cx="240" cy="30" r="3" fill="#FB7185"/>
            <circle cx="300" cy="10" r="4" fill="#FB7185" stroke="white" stroke-width="2"/>
          </svg>
          <div class="grid grid-cols-3 gap-4 mt-6 pt-4 border-t border-gray-100">
            <div class="text-center">
              <div class="stat-number text-2xl font-heading font-bold text-brand">3-6</div>
              <div class="text-xs text-text-muted mt-1">Months to results</div>
            </div>
            <div class="text-center">
              <div class="stat-number text-2xl font-heading font-bold text-accent">300%</div>
              <div class="text-xs text-text-muted mt-1">Map Pack CTR lift</div>
            </div>
            <div class="text-center">
              <div class="stat-number text-2xl font-heading font-bold text-brand">£350</div>
              <div class="text-xs text-text-muted mt-1">Starting from/mo</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="fade-up py-8 my-8">
    <div class="glass-card rounded-2xl p-6 md:p-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="stat-number text-3xl md:text-4xl font-heading font-extrabold text-brand">240k+</div>
          <div class="text-sm text-text-muted mt-1">Swansea population</div>
        </div>
        <div>
          <div class="stat-number text-3xl md:text-4xl font-heading font-extrabold text-accent">4M+</div>
          <div class="text-sm text-text-muted mt-1">Annual visitors</div>
        </div>
        <div>
          <div class="stat-number text-3xl md:text-4xl font-heading font-extrabold text-brand">8.5B</div>
          <div class="text-sm text-text-muted mt-1">Daily Google searches</div>
        </div>
        <div>
          <div class="stat-number text-3xl md:text-4xl font-heading font-extrabold text-accent">80%</div>
          <div class="text-sm text-text-muted mt-1">Check online first</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Answer -->
  <div class="fade-up bg-surface-warm border-l-4 border-accent p-5 rounded-r-xl my-10 shadow-sm">
    <p class="font-semibold text-brand mb-1">Quick Answer</p>
    <p class="text-text-muted">
      SEO Swansea provides local search engine optimisation for businesses in Swansea, Neath Port Talbot, and South Wales. We offer a <a href="/free-seo-audit-swansea/" class="text-accent hover:underline font-medium">free SEO audit</a> to pinpoint your biggest ranking opportunities, then deliver monthly SEO services from £350/month. Most of our clients see clear improvements within three to six months.
    </p>
  </div>

  <!-- Why Local SEO -->
  <section class="fade-up space-y-6 my-16">
    <h2 class="text-3xl font-heading font-bold text-brand">Why Swansea Businesses Need Local SEO</h2>
    <p class="text-text-muted leading-relaxed">
      Swansea is the second-largest city in Wales, with over 240,000 people and a wider catchment stretching from Llanelli in the west to Neath Port Talbot in the east. More than four million visitors come through each year for Swansea Bay, the Gower Peninsula, and the National Waterfront Museum. Every one of those residents and visitors reaches for their phone when they need a local service.
    </p>
    <p class="text-text-muted leading-relaxed">
      Google handles roughly 8.5 billion searches a day worldwide. A huge chunk have local intent: "dentist near me", "best restaurant Swansea", "plumber SA1". If your business doesn't show up, you're invisible to people ready to spend right now.
    </p>

    <!-- Bento Grid: 3 local SEO pillars -->
    <div class="grid md:grid-cols-3 gap-4 mt-8">
      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 0ms">
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Google Map Pack</h3>
        <p class="text-sm text-text-muted leading-relaxed">The three-business panel above organic results. Getting in here can boost clicks by 300% compared to a standard listing.</p>
      </div>
      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 80ms">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Localised Rankings</h3>
        <p class="text-sm text-text-muted leading-relaxed">Google tailors results by location. A business in Uplands can outrank national competitors for nearby searches — with the right signals.</p>
      </div>
      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 160ms">
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Google Business Profile</h3>
        <p class="text-sm text-text-muted leading-relaxed">Your free listing on Google Maps. Optimised profiles with reviews and accurate info drive calls, directions, and visits straight from search.</p>
      </div>
    </div>

    <p class="text-text-muted leading-relaxed mt-6">
      Without local SEO, your Swansea business depends on paid ads, social media algorithms, or word of mouth alone. A page that ranks today keeps generating traffic for months or years without extra spend.
    </p>
  </section>

  <!-- Services Bento Grid -->
  <section class="fade-up my-16">
    <h2 class="text-3xl font-heading font-bold text-brand mb-3">Our SEO Services</h2>
    <p class="text-text-muted leading-relaxed mb-8">
      Every project kicks off with a thorough audit so we understand where you stand, who you're up against, and the fastest routes to better rankings. <a href="/services/" class="text-accent hover:underline font-medium">View all services</a>.
    </p>

    <div class="grid md:grid-cols-2 gap-4">
      <!-- Local SEO - spans full width -->
      <div class="md:col-span-2 glass-card rounded-xl p-6 fade-up relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-32 h-32 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle, rgba(251,113,133,0.08), transparent 70%);"></div>
        <div class="relative z-10 flex flex-col md:flex-row md:items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-heading font-semibold text-text mb-1">Local SEO</h3>
            <p class="text-sm text-text-muted leading-relaxed">Google Business Profile optimisation, consistent citations, local schema markup, and content genuinely relevant to your area. The bread and butter for Swansea businesses chasing local customers.</p>
          </div>
        </div>
      </div>

      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 80ms">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Technical SEO</h3>
        <p class="text-sm text-text-muted leading-relaxed">Page speed, crawlability, mobile usability, structured data. We fix the under-the-bonnet issues holding your site back. <a href="/technical-seo-swansea/" class="text-accent hover:underline">Learn more</a></p>
      </div>

      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 160ms">
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">SEO Audits</h3>
        <p class="text-sm text-text-muted leading-relaxed">On-page content, technical health, backlinks, competitors, local signals — all in a prioritised action plan. <a href="/seo-audit-swansea/" class="text-accent hover:underline">Learn more</a></p>
      </div>

      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 240ms">
        <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Content Strategy</h3>
        <p class="text-sm text-text-muted leading-relaxed">We dig into the queries Swansea customers use, map content gaps, and produce pages that answer real questions properly.</p>
      </div>

      <div class="glass-card rounded-xl p-6 fade-up" style="transition-delay: 320ms">
        <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-text mb-2">Link Building</h3>
        <p class="text-sm text-text-muted leading-relaxed">Local partnerships, industry directories, PR outreach. Links from Swansea BID, South Wales Chamber, and community groups carry real weight.</p>
      </div>
    </div>
  </section>

  <!-- Areas Section -->
  <section class="fade-up my-16">
    <h2 class="text-3xl font-heading font-bold text-brand mb-3">Areas We Cover</h2>
    <p class="text-text-muted leading-relaxed mb-8">
      Each area has its own search patterns and competitive quirks. We build that into our strategy. <a href="/areas/" class="text-accent hover:underline font-medium">View all areas</a>.
    </p>
    <div class="grid md:grid-cols-2 gap-4">
      <div class="glass-card rounded-xl p-5 fade-up" style="transition-delay: 0ms">
        <h3 class="font-heading font-semibold text-text mb-2">Swansea City Centre & SA1</h3>
        <p class="text-sm text-text-muted leading-relaxed">The commercial heart — Meridian Tower, Swansea Marina, and a growing tech cluster. Businesses compete for high-intent searches from office workers and visitors.</p>
      </div>
      <div class="glass-card rounded-xl p-5 fade-up" style="transition-delay: 80ms">
        <h3 class="font-heading font-semibold text-text mb-2">Mumbles</h3>
        <p class="text-sm text-text-muted leading-relaxed">Coastal village with thriving independent retail. Mumbles Pier and the promenade draw tourists year-round with seasonal search spikes SEO can capture.</p>
      </div>
      <div class="glass-card rounded-xl p-5 fade-up" style="transition-delay: 160ms">
        <h3 class="font-heading font-semibold text-text mb-2">Sketty & Uplands</h3>
        <p class="text-sm text-text-muted leading-relaxed">Near Swansea University and Singleton Park. High footfall from students and young professionals creates demand for food, fitness, beauty, and retail.</p>
      </div>
      <div class="glass-card rounded-xl p-5 fade-up" style="transition-delay: 240ms">
        <h3 class="font-heading font-semibold text-text mb-2">Morriston & Enterprise Park</h3>
        <p class="text-sm text-text-muted leading-relaxed">Morriston Hospital and Enterprise Park host B2B and trade businesses. SEO focuses on commercial-intent queries across the SA6 postcode.</p>
      </div>
    </div>
    <p class="text-text-muted leading-relaxed mt-6 text-sm">
      Also covering: Gorseinon, Neath, Port Talbot, Llanelli, and right across the South Wales corridor.
    </p>
  </section>

  <!-- Industries -->
  <section class="fade-up my-16">
    <h2 class="text-3xl font-heading font-bold text-brand mb-3">Industries We Work With</h2>
    <p class="text-text-muted leading-relaxed mb-8">
      Swansea's economy spans tourism, healthcare, education, professional services, and a growing tech sector. <a href="/industries/" class="text-accent hover:underline font-medium">View industry details</a>.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="fade-up" style="transition-delay: 0ms">
        <h3 class="text-lg font-heading font-semibold text-text mb-2 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent"></span>
          Tourism & Hospitality
        </h3>
        <p class="text-sm text-text-muted leading-relaxed pl-4">Hotels, restaurants, activity providers competing for "things to do in Swansea" and seasonal visitor searches. Content calendars timed to search patterns.</p>
      </div>
      <div class="fade-up" style="transition-delay: 80ms">
        <h3 class="text-lg font-heading font-semibold text-text mb-2 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-brand"></span>
          Healthcare
        </h3>
        <p class="text-sm text-text-muted leading-relaxed pl-4">Private dentists, physios, and wellness clinics face strict YMYL requirements. We build strategies that show expertise, authority, and trust.</p>
      </div>
      <div class="fade-up" style="transition-delay: 160ms">
        <h3 class="text-lg font-heading font-semibold text-text mb-2 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-accent"></span>
