---
import Base from '../../layouts/Base.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://seoswansea.uk/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://seoswansea.uk/services/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "SEO Services Swansea | Full-Service SEO | SEO Swansea",
    "description": "Friendly, full-service SEO in Swansea. Local search, technical fixes, content, link building, and AI search optimisation for businesses across SA1 and South Wales.",
    "url": "https://seoswansea.uk/services/",
    "isPartOf": { "@type": "WebSite", "name": "SEO Swansea", "url": "https://seoswansea.uk/" }
  },
  {
    "@context": "https://schema.org",
